# Backend
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://netlens:netlens@postgres:5432/netlens
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:5173","http://localhost:8088"]
AUTH_ENABLED=false
KEYCLOAK_ISSUER_URL=https://keycloak.example.com/realms/netlens
KEYCLOAK_AUDIENCE=netlens-api

# Integrations: keep mock mode on until real endpoints/index fields are mapped
NETBOX_MODE=mock
NETBOX_URL=https://netbox.example.com
NETBOX_TOKEN=change-me
NETBOX_VERIFY_SSL=true

OPENSEARCH_MODE=mock
OPENSEARCH_URL=https://opensearch.example.com:9200
OPENSEARCH_USERNAME=change-me
OPENSEARCH_PASSWORD=change-me
OPENSEARCH_VERIFY_SSL=true
OPENSEARCH_INDEX_PATTERN=logs-*

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
VITE_AUTH_ENABLED=false
VITE_KEYCLOAK_URL=https://keycloak.example.com
VITE_KEYCLOAK_REALM=netlens
VITE_KEYCLOAK_CLIENT_ID=netlens-ui
